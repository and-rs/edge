# Root .env for local dev. scripts/dev.sh loads this file first.
# Existing shell env still wins over values here.

# Required for OpenAI OAuth mode.
STINT_AI_MODEL=gpt-5-mini

# Auth mode: disabled, api-key, or openai-oauth
STINT_AI_AUTH_MODE=api-key

# API-key mode
STINT_AI_API_KEY=
STINT_AI_API_MODEL=deepseek/deepseek-v4-flash

# Provider config
STINT_AI_BASE_URL=https://api.openai.com/v1
# Optional
# STINT_AI_ORG_ID=
# STINT_AI_PROJECT_ID=
# STINT_DEBUG_AI=0

# Judge tuning
STINT_AI_REASONING_EFFORT=low
STINT_AI_TIMEOUT_SECONDS=20
STINT_SIGNALS_CACHE_SECONDS=20

# OAuth mode only. Leave empty to use default profile path.
STINT_AI_OAUTH_PROFILE=