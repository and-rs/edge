# Root .env for local dev. scripts/dev.sh loads this file first.
# Existing shell env still wins over values here.

# AI judging. Set auth mode to disabled for frontend-only iteration.
EDGE_AI_AUTH_MODE=api-key
EDGE_AI_MODEL=deepseek/deepseek-v4-flash
EDGE_AI_API_KEY=

# If using OpenAI-compatible provider, override base URL.
EDGE_AI_BASE_URL=https://api.openai.com/v1
# Optional
# EDGE_AI_ORG_ID=
# EDGE_AI_PROJECT_ID=
# EDGE_DEBUG_AI=0

EDGE_AI_TIMEOUT_SECONDS=20
EDGE_SIGNALS_CACHE_SECONDS=20
